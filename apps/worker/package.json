{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Background job worker for nEIP (pg-boss queue processor)",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@neip/ai": "workspace:*",
    "@neip/core": "workspace:*",
    "@neip/db": "workspace:*",
    "@neip/shared": "workspace:*",
    "pg-boss": "^12.14.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "*"
  }
}
