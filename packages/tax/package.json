{
  "name": "@neip/tax",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Tax calculation engine for nEIP — VAT, WHT, Thai date utilities",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@neip/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  }
}
