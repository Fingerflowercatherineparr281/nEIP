{
  "name": "@neip/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Database layer — Drizzle ORM schemas and migrations for nEIP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neip/shared": "workspace:*",
    "drizzle-orm": "0.44.0",
    "postgres": "^3.4.8",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "*"
  }
}
