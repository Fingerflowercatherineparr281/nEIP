{
  "name": "@neip/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI/LLM integration layer for nEIP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@neip/core": "workspace:*",
    "@neip/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  }
}
